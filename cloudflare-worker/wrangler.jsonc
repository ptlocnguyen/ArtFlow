{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "artflow-pos-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-18",
  "workers_dev": true,
  "vars": {
    "ALLOWED_ORIGINS": "https://ptlocnguyen.github.io,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500"
  },
  "secrets": {
    "required": [
      "APPS_SCRIPT_URL"
    ]
  }
}
